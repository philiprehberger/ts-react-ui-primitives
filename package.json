{
  "name": "@philiprehberger/react-ui-primitives",
  "version": "0.2.0",
  "description": "Lightweight React UI primitives - Button, Alert, and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "clsx": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "clsx": "^2.1.0",
    "react": "^19.0.0",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1"
  },
  "keywords": [
    "react",
    "ui",
    "button",
    "alert",
    "components",
    "primitives"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-react-ui-primitives.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-react-ui-primitives#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-react-ui-primitives/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
